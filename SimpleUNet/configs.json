{
  "command": "train",
  "experiment_name": "ground_truth_training",
  "train":{
    "image": "../EndoSRR-master/EndoRR_dataset/train/image",
    "mask": "../EndoSRR-master/EndoRR_dataset/train/mask"},
  "val":{
    "image": "../EndoSRR-master/EndoRR_dataset/test/image",
    "mask": "../EndoSRR-master/EndoRR_dataset/test/mask"},
  "test":{
    "image": "../EndoSRR-master/EndoRR_dataset/test/image",
    "mask": "../EndoSRR-master/EndoRR_dataset/test/mask"},
  "gpu": "0",
  "num_epochs": 200,
  "batch_size": 4,
  "img_size_x": 640,
  "img_size_y": 512, 
  "supervised_only": true,
  "num_workers": 0,
  "initial_lr": 0.0001,
  "LRonPlateau": true,
  "confidence_threshold": 0.9,
  "drop_rate": 0.5,
  "bn_momentum": 0.1,
  "weight_decay": 0.0006,
  "write_images": true,
  "write_images_interval": 10
}
